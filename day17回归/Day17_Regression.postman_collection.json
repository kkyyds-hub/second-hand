{
  "info": {
    "_postman_id": "c8d2807f-95f8-4a8f-b240-2d89ae23b9d8",
    "name": "Day17 Regression (Local)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var url = pm.request.url.toString();",
          "var tag = pm.environment.get('runTag');",
          "if (!tag) { tag = Date.now().toString().slice(-8); pm.environment.set('runTag', tag); }",
          "pm.environment.set('title_d', 'DAY17-D-' + tag);",
          "pm.environment.set('title_e', 'DAY17-E-' + tag);",
          "pm.environment.set('title_f', 'DAY17-F-' + tag);",
          "pm.environment.set('shippingAddress_d', 'Day17收货地址D-' + tag);",
          "pm.environment.set('shippingAddress_e', 'Day17收货地址E-' + tag);",
          "if (url.includes('/admin/') && !url.includes('/admin/employee/login')) {",
          "  var tAdmin = pm.environment.get('token_admin'); if (tAdmin) pm.request.headers.upsert({ key: 'token', value: tAdmin });",
          "}",
          "if (url.includes('/user/') && !url.includes('/user/auth/')) {",
          "  var reqName = pm.info && pm.info.requestName ? pm.info.requestName : '';",
          "  var useSeller = reqName.indexOf('[Seller]') === 0;",
          "  var tBuyer = pm.environment.get('token_buyer');",
          "  var tSeller = pm.environment.get('token_seller');",
          "  var t = useSeller ? (tSeller || tBuyer) : tBuyer;",
          "  if (t) pm.request.headers.upsert({ key: 'authentication', value: t });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01-Auth",
      "item": [
        {
          "name": "Buyer Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/user/auth/login/password",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginId\": \"{{buyer_username}}\",\n  \"password\": \"{{buyer_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('code == 1', function () { pm.expect(j.code).to.eql(1); });",
                  "pm.test('buyer token exists', function () { pm.expect(j.data && j.data.token).to.be.ok; });",
                  "if (j.code === 1 && j.data && j.data.token) { pm.environment.set('token_buyer', j.data.token); if (j.data.user && j.data.user.id) pm.environment.set('buyerId', String(j.data.user.id)); }"
                ]
              }
            }
          ]
        },
