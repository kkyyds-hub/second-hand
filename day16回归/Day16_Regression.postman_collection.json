{
  "info": {
    "_postman_id": "1f4e6678-9c14-4f8b-9f38-5f6a16d4e201",
    "name": "Day16 Regression (Local)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var url = pm.request.url.toString();",
          "var tag = pm.environment.get('runTag');",
          "if (!tag) {",
          "  tag = Date.now().toString().slice(-8);",
          "  pm.environment.set('runTag', tag);",
          "}",
          "pm.environment.set('title_a', 'DAY16-A-' + tag);",
          "pm.environment.set('title_b', 'DAY16-B-' + tag);",
          "pm.environment.set('title_c', 'DAY16-C-' + tag);",
          "",
          "if (url.includes('/admin/') && !url.includes('/admin/employee/login')) {",
          "  var tAdmin = pm.environment.get('token_admin');",
          "  if (tAdmin) pm.request.headers.upsert({ key: 'token', value: tAdmin });",
          "}",
          "",
          "if (url.includes('/user/') && !url.includes('/user/auth/')) {",
          "  var reqName = pm.info && pm.info.requestName ? pm.info.requestName : '';",
          "  var useSeller = reqName.indexOf('[Seller]') === 0;",
          "  var tBuyer = pm.environment.get('token_buyer');",
          "  var tSeller = pm.environment.get('token_seller');",
          "  var t = useSeller ? (tSeller || tBuyer) : tBuyer;",
          "  if (t) pm.request.headers.upsert({ key: 'authentication', value: t });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01-Auth",
      "item": [
        {
          "name": "Buyer Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/user/auth/login/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginId\": \"{{buyer_username}}\",\n  \"password\": \"{{buyer_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('code == 1', function () { pm.expect(j.code).to.eql(1); });",
                  "pm.test('buyer token exists', function () { pm.expect(j.data && j.data.token).to.be.ok; });",
                  "if (j && j.code === 1 && j.data && j.data.token) {",
                  "  pm.environment.set('token_buyer', j.data.token);",
                  "  if (j.data.user && j.data.user.id) pm.environment.set('buyerId', String(j.data.user.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Seller Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/user/auth/login/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginId\": \"{{seller_username}}\",\n  \"password\": \"{{seller_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('code == 1', function () { pm.expect(j.code).to.eql(1); });",
                  "pm.test('seller token exists', function () { pm.expect(j.data && j.data.token).to.be.ok; });",
                  "if (j && j.code === 1 && j.data && j.data.token) {",
                  "  pm.environment.set('token_seller', j.data.token);",
                  "  if (j.data.user && j.data.user.id) pm.environment.set('sellerId', String(j.data.user.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/employee/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loginId\": \"{{admin_loginId}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('code == 1', function () { pm.expect(j.code).to.eql(1); });",
                  "pm.test('admin token exists', function () { pm.expect(j.data && j.data.token).to.be.ok; });",
                  "if (j && j.code === 1 && j.data && j.data.token) {",
                  "  pm.environment.set('token_admin', j.data.token);",
                  "  if (j.data.user && j.data.user.id) pm.environment.set('adminId', String(j.data.user.id));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
